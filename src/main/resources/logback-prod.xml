<configuration>

  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
  <springProperty name="SLACK_WEBHOOK_URI" source="logging.slack.webhook.uri"/>
  <!-- console appender -->
  <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <Pattern>${CONSOLE_LOG_PATTERN}</Pattern>
      <charset>utf8</charset>
    </encoder>
  </appender>

  <!-- slack appender (error) -->
  <appender name="SLACK" class="com.github.maricn.logback.SlackAppender">
    <webhookUri>${SLACK_WEBHOOK_URI}</webhookUri>
    <layout class="ch.qos.logback.classic.PatternLayout">
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} - %-5le %logger{35} : %msg%n</pattern>
    </layout>
    <username>INDP-SERVER-ERROR</username>
    <iconEmoji>:hammer_and_wrench:</iconEmoji>
    <colorCoding>true</colorCoding>
  </appender>

  <appender name="ASYNC_SLACK" class="ch.qos.logback.classic.AsyncAppender">
    <appender-ref ref="SLACK"/>
    <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
      <level>ERROR</level>
    </filter>
  </appender>

  <!-- slack appender (business event) -->
  <appender name="SLACK_BUSINESS" class="com.github.maricn.logback.SlackAppender">
    <webhookUri>${SLACK_WEBHOOK_URI}</webhookUri>
    <layout class="ch.qos.logback.classic.PatternLayout">
      <pattern>%msg%n</pattern>
    </layout>
    <username>INDP-BUSINESS</username>
    <iconEmoji>:bell:</iconEmoji>
  </appender>

  <appender name="ASYNC_SLACK_BUSINESS" class="ch.qos.logback.classic.AsyncAppender">
    <appender-ref ref="SLACK_BUSINESS"/>
  </appender>

  <logger name="com.verby.indp.slack" level="INFO" additivity="false">
    <appender-ref ref="ASYNC_SLACK_BUSINESS"/>
  </logger>

  <root level="INFO">
    <appender-ref ref="ASYNC_SLACK"/>
    <appender-ref ref="Console"/>
  </root>
</configuration>
